---
// Client-side Crop / Rotate editor. Shared because both tools need the same
// local image intake, HEIC decode, Canvas export, and ZIP packaging.
import AdSlot from '../AdSlot.astro';

type Props = { mode: 'crop' | 'rotate' };
const { mode } = Astro.props;
const isCrop = mode === 'crop';
const title = isCrop ? 'Drop one image here.' : 'Drop images here.';
const subcopy = isCrop
  ? 'Crop one photo at a time with draggable handles. HEIC, JPG, PNG, WebP, GIF & more.'
  : 'Rotate, straighten or flip one image — or apply the same turn to a whole batch.';
const action = isCrop ? 'Crop & download' : 'Rotate & download';
---
<section id="tool" data-mode={mode} class="mx-auto max-w-[1320px] px-5 sm:px-8 pt-10 pb-16">
  <div class="grid lg:grid-cols-[minmax(0,1fr)_320px] gap-8">
    <div>
      <div
        id="dropzone"
        class="drop-target relative rounded-sm p-10 md:p-14 text-center cursor-pointer"
        role="button"
        tabindex="0"
        aria-label={isCrop ? 'Drop an image here, or click to browse' : 'Drop images here, or click to browse'}
      >
        <div class="scanline rounded-sm" data-scanline hidden></div>
        <div class="relative">
          <div class="mx-auto w-14 h-14 inline-flex items-center justify-center rounded-sm bg-[var(--color-emerald-lt)] text-[var(--color-emerald-dk)]">
            {isCrop ? (
              <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 3v4M7 7H3M17 17v4M17 17h4M7 7h10v10H7z"/></svg>
            ) : (
              <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
            )}
          </div>
          <h2 class="mt-5 display-3">{title}</h2>
          <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">
            Drag straight from a file window — or <button type="button" id="browse" class="underline decoration-[var(--color-emerald-dk)] decoration-2 underline-offset-4">browse</button>.
            {subcopy}
          </p>
        </div>
        <input id="file-input" type="file" multiple={!isCrop} class="sr-only" />
      </div>

      <div id="file-panel" class="mt-6 hidden">
        <div class="card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-2.5">
              <span class="chip chip-ink" id="chip-count">0 files</span>
              <span class="chip" id="chip-size">0 B</span>
            </div>
            <div class="flex items-center gap-2">
              <button type="button" id="add-more" class="btn btn-ghost !py-2 !px-3">{isCrop ? 'Replace image' : 'Add more'}</button>
              <button type="button" id="clear-all" class="btn btn-ghost !py-2 !px-3">Clear</button>
            </div>
          </div>

          <div class="grid xl:grid-cols-[minmax(0,1fr)_290px] gap-5 items-start">
            <div class="min-w-0">
              <div id="canvas-shell" class="relative overflow-auto rounded-sm border border-[var(--color-rule)] bg-[var(--color-paper-2)] min-h-[280px] flex items-center justify-center p-3">
                <div id="canvas-wrap" class="relative inline-block max-w-full">
                  <canvas id="preview-canvas" class="block max-w-full max-h-[68vh] bg-[var(--color-paper)]"></canvas>
                  {isCrop && (
                    <div id="crop-box" class="absolute border-2 border-[var(--color-emerald)] bg-[color-mix(in_srgb,var(--color-emerald)_14%,transparent)] shadow-[0_0_0_9999px_rgba(0,0,0,0.28)] cursor-move hidden">
                      {['n','e','s','w','nw','ne','sw','se'].map((h) => (
                        <span data-handle={h} class:list={[
                          'absolute w-4 h-4 bg-[var(--color-paper)] border-2 border-[var(--color-emerald)] rounded-full',
                          h === 'n'  && 'left-1/2 -translate-x-1/2 -top-2 cursor-ns-resize',
                          h === 'e'  && '-right-2 top-1/2 -translate-y-1/2 cursor-ew-resize',
                          h === 's'  && 'left-1/2 -translate-x-1/2 -bottom-2 cursor-ns-resize',
                          h === 'w'  && '-left-2 top-1/2 -translate-y-1/2 cursor-ew-resize',
                          h === 'nw' && '-left-2 -top-2 cursor-nwse-resize',
                          h === 'ne' && '-right-2 -top-2 cursor-nesw-resize',
                          h === 'sw' && '-left-2 -bottom-2 cursor-nesw-resize',
                          h === 'se' && '-right-2 -bottom-2 cursor-nwse-resize',
                        ]}></span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              <p id="hint" class="mt-2 text-xs text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
                {isCrop ? 'Drag the crop frame or pull a corner handle. Export uses the original pixels, not the preview size.' : 'The same rotation settings apply to every selected image when you download a batch.'}
              </p>
            </div>

            <div class="space-y-5">
              <ul id="file-list" class="divide-y divide-[var(--color-rule)] max-h-[260px] overflow-auto border border-[var(--color-rule)] rounded-sm"></ul>

              {isCrop ? (
                <div class="rule pt-5">
                  <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Crop shape</div>
                  <div class="mt-2 grid grid-cols-2 gap-2" role="radiogroup" aria-label="Crop aspect ratio">
                    {[
                      ['free', 'Free'],
                      ['1:1', 'Square'],
                      ['4:3', '4:3'],
                      ['16:9', '16:9'],
                    ].map(([value, label]) => (
                      <label class="cursor-pointer">
                        <input type="radio" name="aspect" value={value} checked={value === 'free'} class="sr-only peer" />
                        <span class="block text-center py-2 px-2 rounded-sm border border-[var(--color-rule)] font-mono text-xs uppercase tracking-[0.1em] peer-checked:bg-[var(--color-navy-800)] peer-checked:text-[var(--color-paper)] peer-checked:border-[var(--color-navy-800)] transition-colors">{label}</span>
                      </label>
                    ))}
                  </div>
                  <div class="mt-3 grid grid-cols-2 gap-2">
                    <button type="button" id="detect-edges" class="btn btn-ghost !justify-center !py-2 !px-3">Detect edges</button>
                    <button type="button" id="full-frame" class="btn btn-ghost !justify-center !py-2 !px-3">Full image</button>
                  </div>
                  <p class="mt-2 text-xs text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
                    Drag a green edge near the label and it snaps to strong nearby image edges when it can.
                  </p>
                </div>
              ) : (
                <div class="rule pt-5 space-y-4">
                  <div>
                    <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Quick turns</div>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                      <button type="button" id="turn-left" class="btn btn-ghost !justify-center !py-2 !px-3">Left 90°</button>
                      <button type="button" id="turn-right" class="btn btn-ghost !justify-center !py-2 !px-3">Right 90°</button>
                      <button type="button" id="flip-x" class="btn btn-ghost !justify-center !py-2 !px-3">Flip H</button>
                      <button type="button" id="flip-y" class="btn btn-ghost !justify-center !py-2 !px-3">Flip V</button>
                    </div>
                  </div>
                  <div>
                    <div class="flex items-center justify-between">
                      <label for="angle" class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Straighten</label>
                      <span class="font-mono text-sm"><span id="angle-val">0</span>°</span>
                    </div>
                    <input id="angle" type="range" min="-45" max="45" step="1" value="0" class="w-full mt-3 accent-[var(--color-emerald-dk)]" />
                  </div>
                  <button type="button" id="reset-transform" class="btn btn-ghost w-full !justify-center !py-2 !px-3">Reset</button>
                </div>
              )}

              <div class="rule pt-5">
                <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Save as</div>
                <div class="mt-2 grid grid-cols-3 gap-2" role="radiogroup" aria-label="Output format">
                  {['jpg', 'png', 'webp'].map((fmt) => (
                    <label class="cursor-pointer">
                      <input type="radio" name="output" value={fmt} checked={fmt === 'jpg'} class="sr-only peer" />
                      <span class="block text-center py-2 px-2 rounded-sm border border-[var(--color-rule)] font-mono text-xs uppercase tracking-[0.1em] peer-checked:bg-[var(--color-navy-800)] peer-checked:text-[var(--color-paper)] peer-checked:border-[var(--color-navy-800)] transition-colors">{fmt}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div id="quality-block" class="rule pt-5">
                <div class="flex items-center justify-between">
                  <label for="quality" class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Image quality</label>
                  <span class="font-mono text-sm"><span id="quality-val">92</span>%</span>
                </div>
                <input id="quality" type="range" min="50" max="100" step="1" value="92" class="w-full mt-3 accent-[var(--color-emerald-dk)]" />
              </div>

              <button id="export-btn" class="btn btn-primary w-full justify-center" disabled>
                {action}
                <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 3v14M6 11l6 6 6-6M5 21h14"/></svg>
              </button>
            </div>
          </div>

          <div class="mt-6 rule pt-5">
            <div class="flex items-center justify-between mb-1.5 font-mono text-[11px] tracking-[0.12em] uppercase text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">
              <span id="status-label">Idle</span>
              <span id="progress-num">0%</span>
            </div>
            <div class="bar"><span id="progress-bar" style="width:0%"></span></div>
          </div>
        </div>
      </div>

      <div id="err" role="alert" class="mt-6 hidden border border-[var(--color-red-stamp)] bg-[var(--color-red-stamp-bg)] text-[var(--color-red-stamp)] font-mono text-xs uppercase tracking-[0.14em] p-3 rounded-sm"></div>
    </div>

    <aside class="space-y-5">
      <div class="card p-5">
        <div class="section-num">Local runtime</div>
        <h3 class="font-display text-[22px] mt-1 leading-tight">What's running?</h3>
        <ul class="mt-3 text-sm space-y-2 font-mono">
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Decoder</span><span>Canvas 2D / libheif</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Editor</span><span>{isCrop ? 'Crop frame' : 'Transform matrix'}</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Network</span><span class="text-[var(--color-emerald-dk)]">idle</span></li>
        </ul>
      </div>
      <AdSlot position={`${mode}-sidebar`} size="300x250" />
      <div class="card-ink p-5">
        <div class="font-mono text-[11px] tracking-[0.2em] uppercase opacity-80">Good to know</div>
        <p class="mt-2 text-[15px] leading-relaxed">
          Exporting creates a fresh file and strips EXIF metadata by default. JPG output flattens transparency onto white; PNG and WebP keep it where the browser can.
        </p>
      </div>
    </aside>
  </div>
</section>

<script>
  import JSZip from 'jszip';
  import { formatBytes, downloadBlob, stripExtension, todayStamp } from '../../lib/format.ts';

  type Item = {
    id: string;
    file: File;
    format: string;
    status: 'ready' | 'loading' | 'done' | 'error';
    source?: HTMLCanvasElement;
    error?: string;
  };
  type Output = 'jpg' | 'png' | 'webp';

  const tool = document.getElementById('tool') as HTMLElement;
  const mode = tool.dataset.mode === 'rotate' ? 'rotate' : 'crop';
  const isCrop = mode === 'crop';
  const dropzone = document.getElementById('dropzone') as HTMLDivElement;
  const input = document.getElementById('file-input') as HTMLInputElement;
  const browse = document.getElementById('browse') as HTMLButtonElement;
  const panel = document.getElementById('file-panel') as HTMLDivElement;
  const addMoreBtn = document.getElementById('add-more') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-all') as HTMLButtonElement;
  const chipCount = document.getElementById('chip-count') as HTMLSpanElement;
  const chipSize = document.getElementById('chip-size') as HTMLSpanElement;
  const listEl = document.getElementById('file-list') as HTMLUListElement;
  const canvasShell = document.getElementById('canvas-shell') as HTMLDivElement;
  const preview = document.getElementById('preview-canvas') as HTMLCanvasElement;
  const wrap = document.getElementById('canvas-wrap') as HTMLDivElement;
  const cropEl = document.getElementById('crop-box') as HTMLDivElement | null;
  const qBlock = document.getElementById('quality-block') as HTMLDivElement;
  const qSlider = document.getElementById('quality') as HTMLInputElement;
  const qVal = document.getElementById('quality-val') as HTMLSpanElement;
  const exportBtn = document.getElementById('export-btn') as HTMLButtonElement;
  const progBar = document.getElementById('progress-bar') as HTMLSpanElement;
  const progNum = document.getElementById('progress-num') as HTMLSpanElement;
  const statusLabel = document.getElementById('status-label') as HTMLSpanElement;
  const errEl = document.getElementById('err') as HTMLDivElement;
  const scan = dropzone.querySelector('[data-scanline]') as HTMLDivElement;
  const angleSlider = document.getElementById('angle') as HTMLInputElement | null;
  const angleVal = document.getElementById('angle-val') as HTMLSpanElement | null;

  const items: Item[] = [];
  let selectedId = '';
  let working = false;
  let quarterAngle = 0;
  let flipX = false;
  let flipY = false;
  let crop = { x: 0.1, y: 0.1, w: 0.8, h: 0.8 };
  const SNAP = 0.035;

  const HEIC_BRANDS = new Set(['heic','heix','heim','heis','mif1','msf1','hevc','hevx','hevm','hevs']);

  async function detectImageFormat(f: File): Promise<string | null> {
    try {
      const buf = await f.slice(0, 32).arrayBuffer();
      const b = new Uint8Array(buf);
      if (b.length < 12) return null;
      if (b[0] === 0xff && b[1] === 0xd8 && b[2] === 0xff) return 'jpg';
      if (b[0] === 0x89 && b[1] === 0x50 && b[2] === 0x4e && b[3] === 0x47) return 'png';
      if (b[0] === 0x47 && b[1] === 0x49 && b[2] === 0x46) return 'gif';
      if (b[0] === 0x42 && b[1] === 0x4d) return 'bmp';
      if (String.fromCharCode(b[0], b[1], b[2], b[3]) === 'RIFF' && String.fromCharCode(b[8], b[9], b[10], b[11]) === 'WEBP') return 'webp';
      if (String.fromCharCode(b[4], b[5], b[6], b[7]) === 'ftyp') {
        const brand = String.fromCharCode(b[8], b[9], b[10], b[11]);
        if (HEIC_BRANDS.has(brand)) return 'heic';
        if (brand === 'avif' || brand === 'avis') return 'avif';
      }
      const name = f.name.toLowerCase();
      if (name.endsWith('.heic') || name.endsWith('.heif')) return 'heic';
      return null;
    } catch {
      return null;
    }
  }

  async function decodeToBitmap(item: Item): Promise<ImageBitmap> {
    if (item.format === 'heic' || item.format === 'heif') {
      const { default: heic2any } = await import('heic2any');
      const result = await heic2any({ blob: item.file, toType: 'image/png' });
      const blob: Blob = Array.isArray(result) ? result[0] : result;
      return await createImageBitmap(blob);
    }
    return await createImageBitmap(item.file, { imageOrientation: 'from-image' });
  }

  async function loadItem(item: Item): Promise<HTMLCanvasElement> {
    if (item.source) return item.source;
    item.status = 'loading';
    render();
    const bitmap = await decodeToBitmap(item);
    const canvas = document.createElement('canvas');
    canvas.width = bitmap.width;
    canvas.height = bitmap.height;
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('canvas unavailable');
    ctx.drawImage(bitmap, 0, 0);
    bitmap.close();
    item.source = canvas;
    item.status = 'ready';
    render();
    return canvas;
  }

  function selected(): Item | undefined {
    return items.find((i) => i.id === selectedId) || items[0];
  }

  function readOutput(): Output {
    const checked = document.querySelector('input[name="output"]:checked') as HTMLInputElement | null;
    return checked?.value === 'png' || checked?.value === 'webp' ? checked.value : 'jpg';
  }

  function quality(): number {
    return Math.max(50, Math.min(100, +qSlider.value)) / 100;
  }

  function setProgress(pct: number, label?: string) {
    const c = Math.max(0, Math.min(100, pct));
    progBar.style.width = `${c}%`;
    progNum.textContent = `${Math.round(c)}%`;
    if (label) statusLabel.textContent = label;
  }

  let errTimer: ReturnType<typeof setTimeout> | undefined;
  function showErr(msg: string) {
    if (errTimer) clearTimeout(errTimer);
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
    errTimer = setTimeout(() => errEl.classList.add('hidden'), 6500);
  }

  function updateOutputUI() {
    qBlock.classList.toggle('hidden', readOutput() === 'png');
  }
  document.querySelectorAll('input[name="output"]').forEach((el) => el.addEventListener('change', updateOutputUI));

  function render() {
    panel.classList.toggle('hidden', items.length === 0);
    const total = items.reduce((acc, item) => acc + item.file.size, 0);
    chipCount.textContent = `${items.length} file${items.length === 1 ? '' : 's'}`;
    chipSize.textContent = formatBytes(total);
    exportBtn.disabled = working || items.length === 0;

    listEl.innerHTML = '';
    for (const item of items) {
      const li = document.createElement('li');
      li.className = 'p-3 flex items-center gap-3 min-w-0';
      const button = document.createElement('button');
      button.type = 'button';
      button.className = `min-w-0 flex-1 text-left rounded-sm p-1 ${item.id === selectedId ? 'bg-[var(--color-paper-2)]' : ''}`;
      const name = document.createElement('div');
      name.className = 'font-display text-[18px] truncate';
      name.textContent = item.file.name;
      const meta = document.createElement('div');
      meta.className = 'font-mono text-[11px] uppercase tracking-[0.12em] text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]';
      meta.textContent = `${item.format.toUpperCase()} · ${formatBytes(item.file.size)} · ${item.status}`;
      button.appendChild(name);
      button.appendChild(meta);
      button.addEventListener('click', () => selectItem(item.id));
      li.appendChild(button);
      const remove = document.createElement('button');
      remove.type = 'button';
      remove.className = 'w-8 h-8 inline-flex items-center justify-center border border-[var(--color-rule)] rounded-sm hover:bg-[var(--color-paper-2)]';
      remove.setAttribute('aria-label', `Remove ${item.file.name}`);
      remove.innerHTML = '<svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 6l12 12M18 6L6 18"/></svg>';
      remove.addEventListener('click', () => {
        const idx = items.findIndex((i) => i.id === item.id);
        if (idx >= 0) items.splice(idx, 1);
        if (selectedId === item.id) selectedId = items[0]?.id ?? '';
        render();
        drawPreview();
      });
      li.appendChild(remove);
      listEl.appendChild(li);
    }
  }

  async function selectItem(id: string) {
    selectedId = id;
    const item = selected();
    if (!item) return;
    try {
      await loadItem(item);
      if (isCrop) {
        resetCrop();
      }
      await drawPreview();
    } catch (err) {
      console.error(err);
      item.status = 'error';
      item.error = (err as Error).message;
      showErr('That image could not be decoded in this browser.');
      render();
    }
  }

  function resetCrop() {
    crop = { x: 0.1, y: 0.1, w: 0.8, h: 0.8 };
    fitCropToAspect();
    paintCropBox();
  }

  function fullCrop() {
    crop = { x: 0, y: 0, w: 1, h: 1 };
    fitCropToAspect();
    paintCropBox();
  }

  function setCropFromDetected(box: typeof crop) {
    crop = { ...box };
    if (aspectRatio()) fitCropToAspect();
    clampCrop();
    paintCropBox();
  }

  function aspectRatio(): number | null {
    const checked = document.querySelector('input[name="aspect"]:checked') as HTMLInputElement | null;
    if (!checked || checked.value === 'free') return null;
    const [w, h] = checked.value.split(':').map(Number);
    return w / h;
  }

  function fitCropToAspect() {
    const ratio = aspectRatio();
    if (!ratio) return;
    let w = crop.w;
    let h = w / ratio;
    if (h > crop.h) {
      h = crop.h;
      w = h * ratio;
    }
    crop.x += (crop.w - w) / 2;
    crop.y += (crop.h - h) / 2;
    crop.w = w;
    crop.h = h;
    clampCrop();
  }

  function clampCrop() {
    crop.w = Math.max(0.05, Math.min(1, crop.w));
    crop.h = Math.max(0.05, Math.min(1, crop.h));
    crop.x = Math.max(0, Math.min(1 - crop.w, crop.x));
    crop.y = Math.max(0, Math.min(1 - crop.h, crop.y));
  }

  function snapTarget(value: number, targets: number[]): number | null {
    let best: number | null = null;
    let bestDist = SNAP;
    for (const target of targets) {
      const dist = Math.abs(value - target);
      if (dist < bestDist) {
        best = target;
        bestDist = dist;
      }
    }
    return best;
  }

  function snapCropToEdges(kind: string = 'resize') {
    const left = crop.x;
    const top = crop.y;
    const right = crop.x + crop.w;
    const bottom = crop.y + crop.h;

    if (kind === 'move') {
      const dx = nearestMoveSnapDelta('x', left, right, top, bottom);
      const dy = nearestMoveSnapDelta('y', top, bottom, left, right);
      if (dx != null) crop.x += dx;
      if (dy != null) crop.y += dy;
    } else {
      let x1 = left;
      let y1 = top;
      let x2 = right;
      let y2 = bottom;
      const snapLeft = kind.includes('w') ? edgeSnap('x', x1, y1, y2) : null;
      const snapRight = kind.includes('e') ? edgeSnap('x', x2, y1, y2) : null;
      const snapTop = kind.includes('n') ? edgeSnap('y', y1, x1, x2) : null;
      const snapBottom = kind.includes('s') ? edgeSnap('y', y2, x1, x2) : null;
      if (snapLeft != null) x1 = snapLeft;
      if (snapRight != null) x2 = snapRight;
      if (snapTop != null) y1 = snapTop;
      if (snapBottom != null) y2 = snapBottom;
      crop = { x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
    }

    clampCrop();
  }

  function nearestMoveSnapDelta(axis: 'x' | 'y', a: number, b: number, rangeA: number, rangeB: number): number | null {
    const snapA = edgeSnap(axis, a, rangeA, rangeB);
    const snapB = edgeSnap(axis, b, rangeA, rangeB);
    const deltaA = snapA == null ? null : snapA - a;
    const deltaB = snapB == null ? null : snapB - b;
    if (deltaA == null) return deltaB;
    if (deltaB == null) return deltaA;
    return Math.abs(deltaA) <= Math.abs(deltaB) ? deltaA : deltaB;
  }

  function edgeSnap(axis: 'x' | 'y', value: number, rangeA: number, rangeB: number): number | null {
    const boundary = snapTarget(value, [0, 1]);
    if (boundary != null) return boundary;
    return findLocalPixelEdge(axis, value, rangeA, rangeB);
  }

  function findLocalPixelEdge(axis: 'x' | 'y', value: number, rangeA: number, rangeB: number): number | null {
    const item = selected();
    const src = item?.source;
    if (!src) return null;
    const ctx = src.getContext('2d', { willReadFrequently: true });
    if (!ctx) return null;
    const { width, height } = src;
    const pixels = ctx.getImageData(0, 0, width, height).data;
    const dim = axis === 'x' ? width : height;
    const crossDim = axis === 'x' ? height : width;
    const center = Math.round(value * dim);
    const radius = Math.max(6, Math.round(dim * SNAP));
    const start = Math.max(1, center - radius);
    const end = Math.min(dim - 1, center + radius);
    const crossStart = Math.max(0, Math.round(Math.min(rangeA, rangeB) * crossDim));
    const crossEnd = Math.min(crossDim - 1, Math.round(Math.max(rangeA, rangeB) * crossDim));
    const step = Math.max(1, Math.round((crossEnd - crossStart) / 220));
    let best = -1;
    let bestScore = 0;

    for (let pos = start; pos <= end; pos++) {
      let score = 0;
      let n = 0;
      for (let cross = crossStart; cross <= crossEnd; cross += step) {
        const p1 = axis === 'x'
          ? (cross * width + pos) * 4
          : (pos * width + cross) * 4;
        const p0 = axis === 'x'
          ? (cross * width + pos - 1) * 4
          : ((pos - 1) * width + cross) * 4;
        const l1 = 0.2126 * pixels[p1] + 0.7152 * pixels[p1 + 1] + 0.0722 * pixels[p1 + 2];
        const l0 = 0.2126 * pixels[p0] + 0.7152 * pixels[p0 + 1] + 0.0722 * pixels[p0 + 2];
        const color = Math.hypot(
          pixels[p1] - pixels[p0],
          pixels[p1 + 1] - pixels[p0 + 1],
          pixels[p1 + 2] - pixels[p0 + 2],
        );
        score += Math.abs(l1 - l0) + color * 0.18;
        n++;
      }
      score /= Math.max(1, n);
      const distancePenalty = Math.abs(pos - center) / Math.max(1, radius) * 7;
      score -= distancePenalty;
      if (score > bestScore) {
        bestScore = score;
        best = pos;
      }
    }

    return bestScore > 16 && best >= 0 ? best / dim : null;
  }

  function paintCropBox() {
    if (!cropEl) return;
    syncOverlaySize();
    cropEl.classList.toggle('hidden', !isCrop || items.length === 0);
    cropEl.style.left = `${crop.x * 100}%`;
    cropEl.style.top = `${crop.y * 100}%`;
    cropEl.style.width = `${crop.w * 100}%`;
    cropEl.style.height = `${crop.h * 100}%`;
  }

  function syncOverlaySize() {
    if (!isCrop || preview.width === 0 || preview.height === 0) return;
    const shellWidth = Math.max(260, canvasShell.clientWidth - 24);
    const maxHeight = Math.max(220, window.innerHeight * 0.68);
    const scale = Math.min(1, shellWidth / preview.width, maxHeight / preview.height);
    const cssW = Math.max(1, Math.round(preview.width * scale));
    const cssH = Math.max(1, Math.round(preview.height * scale));
    preview.style.width = `${cssW}px`;
    preview.style.height = `${cssH}px`;
    wrap.style.width = `${cssW}px`;
    wrap.style.height = `${cssH}px`;
  }

  function transformCanvas(src: HTMLCanvasElement): HTMLCanvasElement {
    const fine = +(angleSlider?.value ?? 0);
    const angle = (quarterAngle + fine) * Math.PI / 180;
    const cos = Math.abs(Math.cos(angle));
    const sin = Math.abs(Math.sin(angle));
    const out = document.createElement('canvas');
    out.width = Math.max(1, Math.ceil(src.width * cos + src.height * sin));
    out.height = Math.max(1, Math.ceil(src.width * sin + src.height * cos));
    const ctx = out.getContext('2d');
    if (!ctx) throw new Error('canvas unavailable');
    ctx.translate(out.width / 2, out.height / 2);
    ctx.rotate(angle);
    ctx.scale(flipX ? -1 : 1, flipY ? -1 : 1);
    ctx.drawImage(src, -src.width / 2, -src.height / 2);
    return out;
  }

  async function drawPreview() {
    const item = selected();
    if (!item) return;
    const src = await loadItem(item);
    const shown = isCrop ? src : transformCanvas(src);
    preview.width = shown.width;
    preview.height = shown.height;
    const ctx = preview.getContext('2d');
    if (!ctx) return;
    ctx.clearRect(0, 0, preview.width, preview.height);
    ctx.drawImage(shown, 0, 0);
    syncOverlaySize();
    paintCropBox();
  }

  async function addFiles(files: FileList | File[]) {
    const arr = Array.from(files);
    let accepted = 0;
    let rejected = 0;
    const incoming: Item[] = [];
    for (const f of arr) {
      const fmt = await detectImageFormat(f);
      if (fmt) {
        incoming.push({ id: crypto.randomUUID(), file: f, format: fmt, status: 'ready' });
        accepted++;
      } else {
        rejected++;
      }
    }
    if (accepted === 0 && rejected > 0) showErr('No supported images there — drop HEIC, JPG, PNG, WebP, GIF or BMP files.');
    else if (rejected > 0) showErr(`${rejected} file${rejected === 1 ? '' : 's'} skipped — not a supported image.`);

    if (incoming.length > 0) {
      if (isCrop) {
        items.splice(0, items.length, incoming[0]);
        if (incoming.length > 1) showErr('Crop works one image at a time, so only the first supported image was loaded.');
      } else {
        items.push(...incoming);
      }
      selectedId = items[0].id;
      render();
      await selectItem(selectedId);
      requestAnimationFrame(() => exportBtn.scrollIntoView({ behavior: 'smooth', block: 'center' }));
    }
  }

  function clearAll() {
    items.length = 0;
    selectedId = '';
    preview.width = 0;
    preview.height = 0;
    preview.style.width = '';
    preview.style.height = '';
    wrap.style.width = '';
    wrap.style.height = '';
    if (cropEl) cropEl.classList.add('hidden');
    setProgress(0, 'Idle');
    render();
  }

  dropzone.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'browse') return;
    input.click();
  });
  dropzone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); }
  });
  browse.addEventListener('click', (e) => { e.stopPropagation(); input.click(); });
  addMoreBtn.addEventListener('click', () => input.click());
  clearBtn.addEventListener('click', clearAll);

  ['dragenter', 'dragover'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    dropzone.classList.add('is-dragging');
    if (scan) scan.hidden = false;
  }));
  ['dragleave', 'drop'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    if (evt === 'dragleave' && e.target !== dropzone) return;
    dropzone.classList.remove('is-dragging');
    if (scan) scan.hidden = true;
  }));
  dropzone.addEventListener('drop', (e) => {
    if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
  });
  input.addEventListener('change', () => {
    if (input.files) addFiles(input.files);
    input.value = '';
  });

  qSlider.addEventListener('input', () => { qVal.textContent = qSlider.value; });
  document.querySelectorAll('input[name="aspect"]').forEach((el) => el.addEventListener('change', () => {
    fitCropToAspect();
    snapCropToEdges('nwse');
    paintCropBox();
  }));
  document.getElementById('full-frame')?.addEventListener('click', fullCrop);
  document.getElementById('detect-edges')?.addEventListener('click', async () => {
    try {
      await detectContentEdges();
    } catch (err) {
      console.error(err);
      showErr('Could not detect a useful edge in this image.');
    }
  });
  window.addEventListener('resize', () => {
    syncOverlaySize();
    paintCropBox();
  });

  if (!isCrop) {
    document.getElementById('turn-left')?.addEventListener('click', () => { quarterAngle -= 90; drawPreview(); });
    document.getElementById('turn-right')?.addEventListener('click', () => { quarterAngle += 90; drawPreview(); });
    document.getElementById('flip-x')?.addEventListener('click', () => { flipX = !flipX; drawPreview(); });
    document.getElementById('flip-y')?.addEventListener('click', () => { flipY = !flipY; drawPreview(); });
    document.getElementById('reset-transform')?.addEventListener('click', () => {
      quarterAngle = 0;
      flipX = false;
      flipY = false;
      if (angleSlider) angleSlider.value = '0';
      if (angleVal) angleVal.textContent = '0';
      drawPreview();
    });
    angleSlider?.addEventListener('input', () => {
      if (angleVal) angleVal.textContent = angleSlider.value;
      drawPreview();
    });
  }

  if (cropEl) {
    let drag: { kind: string; sx: number; sy: number; start: typeof crop } | null = null;
    cropEl.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      const target = e.target as HTMLElement;
      drag = {
        kind: target.dataset.handle || 'move',
        sx: e.clientX,
        sy: e.clientY,
        start: { ...crop },
      };
      cropEl.setPointerCapture(e.pointerId);
    });
    cropEl.addEventListener('pointermove', (e) => {
      if (!drag) return;
      const rect = wrap.getBoundingClientRect();
      const dx = (e.clientX - drag.sx) / rect.width;
      const dy = (e.clientY - drag.sy) / rect.height;
      const s = drag.start;
      if (drag.kind === 'move') {
        crop.x = s.x + dx;
        crop.y = s.y + dy;
      } else {
        let x1 = s.x;
        let y1 = s.y;
        let x2 = s.x + s.w;
        let y2 = s.y + s.h;
        if (drag.kind.includes('w')) x1 = s.x + dx;
        if (drag.kind.includes('e')) x2 = s.x + s.w + dx;
        if (drag.kind.includes('n')) y1 = s.y + dy;
        if (drag.kind.includes('s')) y2 = s.y + s.h + dy;
        if (x2 < x1) [x1, x2] = [x2, x1];
        if (y2 < y1) [y1, y2] = [y2, y1];
        crop = { x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
        const ratio = aspectRatio();
        if (ratio) {
          if (crop.w / crop.h > ratio) crop.w = crop.h * ratio;
          else crop.h = crop.w / ratio;
        }
      }
      clampCrop();
      snapCropToEdges(drag.kind);
      paintCropBox();
    });
    cropEl.addEventListener('pointerup', () => { drag = null; });
    cropEl.addEventListener('pointercancel', () => { drag = null; });
  }

  async function detectContentEdges() {
    const item = selected();
    if (!item) return;
    const src = await loadItem(item);
    const ctx = src.getContext('2d', { willReadFrequently: true });
    if (!ctx) throw new Error('canvas unavailable');

    const { width, height } = src;
    const data = ctx.getImageData(0, 0, width, height).data;

    // First pass: find a dominant bright / high-contrast rectangular region.
    // This catches the common "crop the label on a bottle / box / package"
    // case where the background itself has texture all the way to the image
    // edge, so simple margin trimming would keep the full photo.
    const labelBox = detectProminentRect(src);
    if (labelBox) {
      setCropFromDetected(labelBox);
      statusLabel.textContent = 'Edges detected';
      return;
    }

    // Fallback: trim transparent or flat-color margins by comparing against
    // the average corner background.
    const sample = Math.max(2, Math.min(10, Math.floor(Math.min(width, height) / 20)));
    const corners = [
      [0, 0],
      [width - sample, 0],
      [0, height - sample],
      [width - sample, height - sample],
    ];
    let r = 0, g = 0, b = 0, a = 0, n = 0;
    for (const [sx, sy] of corners) {
      for (let y = sy; y < sy + sample; y++) {
        for (let x = sx; x < sx + sample; x++) {
          const i = (y * width + x) * 4;
          r += data[i];
          g += data[i + 1];
          b += data[i + 2];
          a += data[i + 3];
          n++;
        }
      }
    }
    const bg = { r: r / n, g: g / n, b: b / n, a: a / n };
    const content = (i: number) => {
      const alpha = data[i + 3];
      if (bg.a < 20) return alpha > 20;
      if (alpha < 12) return false;
      const dr = data[i] - bg.r;
      const dg = data[i + 1] - bg.g;
      const db = data[i + 2] - bg.b;
      const da = alpha - bg.a;
      return Math.hypot(dr, dg, db, da * 0.6) > 34;
    };

    let minX = width, minY = height, maxX = -1, maxY = -1;
    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        if (!content((y * width + x) * 4)) continue;
        if (x < minX) minX = x;
        if (y < minY) minY = y;
        if (x > maxX) maxX = x;
        if (y > maxY) maxY = y;
      }
    }

    if (maxX < minX || maxY < minY) {
      showErr('No clear content edge found — try dragging the crop frame manually.');
      return;
    }

    const pad = Math.max(0, Math.round(Math.min(width, height) * 0.004));
    minX = Math.max(0, minX - pad);
    minY = Math.max(0, minY - pad);
    maxX = Math.min(width - 1, maxX + pad);
    maxY = Math.min(height - 1, maxY + pad);

    const w = maxX - minX + 1;
    const h = maxY - minY + 1;
    if (w > width * 0.985 && h > height * 0.985) {
      showErr('Edges already fill the image.');
      fullCrop();
      return;
    }

    setCropFromDetected({ x: minX / width, y: minY / height, w: w / width, h: h / height });
    statusLabel.textContent = 'Edges detected';
  }

  function detectProminentRect(src: HTMLCanvasElement): typeof crop | null {
    const maxDim = 360;
    const scale = Math.min(1, maxDim / Math.max(src.width, src.height));
    const width = Math.max(1, Math.round(src.width * scale));
    const height = Math.max(1, Math.round(src.height * scale));
    const probe = document.createElement('canvas');
    probe.width = width;
    probe.height = height;
    const ctx = probe.getContext('2d', { willReadFrequently: true });
    if (!ctx) return null;
    ctx.drawImage(src, 0, 0, width, height);
    const data = ctx.getImageData(0, 0, width, height).data;
    const total = width * height;

    let lumaSum = 0;
    let lumaSq = 0;
    for (let i = 0; i < data.length; i += 4) {
      const l = 0.2126 * data[i] + 0.7152 * data[i + 1] + 0.0722 * data[i + 2];
      lumaSum += l;
      lumaSq += l * l;
    }
    const mean = lumaSum / total;
    const variance = Math.max(0, lumaSq / total - mean * mean);
    const std = Math.sqrt(variance);

    const sample = Math.max(3, Math.min(12, Math.floor(Math.min(width, height) / 18)));
    const cornerStarts = [
      [0, 0],
      [width - sample, 0],
      [0, height - sample],
      [width - sample, height - sample],
    ];
    let br = 0, bg = 0, bb = 0, ba = 0, bn = 0;
    for (const [sx, sy] of cornerStarts) {
      for (let y = sy; y < sy + sample; y++) {
        for (let x = sx; x < sx + sample; x++) {
          const i = (y * width + x) * 4;
          br += data[i];
          bg += data[i + 1];
          bb += data[i + 2];
          ba += data[i + 3];
          bn++;
        }
      }
    }
    const corner = { r: br / bn, g: bg / bn, b: bb / bn, a: ba / bn };
    const cornerLuma = 0.2126 * corner.r + 0.7152 * corner.g + 0.0722 * corner.b;
    const lumaCut = Math.max(mean + std * 0.32, cornerLuma + 26);
    const mask = new Uint8Array(total);

    for (let p = 0; p < total; p++) {
      const i = p * 4;
      const alpha = data[i + 3];
      if (alpha < 20) continue;
      const r = data[i];
      const g = data[i + 1];
      const b = data[i + 2];
      const luma = 0.2126 * r + 0.7152 * g + 0.0722 * b;
      const colorDist = Math.hypot(r - corner.r, g - corner.g, b - corner.b, (alpha - corner.a) * 0.35);
      if (luma > lumaCut || (luma > cornerLuma + 12 && colorDist > 52)) {
        mask[p] = 1;
      }
    }

    const projected = detectProjectedLabel(mask, width, height);
    if (projected) return projected;

    const visited = new Uint8Array(total);
    const queue = new Int32Array(total);
    let best: { score: number; minX: number; minY: number; maxX: number; maxY: number } | null = null;

    for (let start = 0; start < total; start++) {
      if (!mask[start] || visited[start]) continue;
      let head = 0;
      let tail = 0;
      queue[tail++] = start;
      visited[start] = 1;
      let area = 0;
      let minX = width;
      let minY = height;
      let maxX = -1;
      let maxY = -1;

      while (head < tail) {
        const p = queue[head++];
        area++;
        const x = p % width;
        const y = Math.floor(p / width);
        if (x < minX) minX = x;
        if (y < minY) minY = y;
        if (x > maxX) maxX = x;
        if (y > maxY) maxY = y;

        for (let oy = -1; oy <= 1; oy++) {
          const ny = y + oy;
          if (ny < 0 || ny >= height) continue;
          for (let ox = -1; ox <= 1; ox++) {
            if (ox === 0 && oy === 0) continue;
            const nx = x + ox;
            if (nx < 0 || nx >= width) continue;
            const np = ny * width + nx;
            if (!mask[np] || visited[np]) continue;
            visited[np] = 1;
            queue[tail++] = np;
          }
        }
      }

      const boxW = maxX - minX + 1;
      const boxH = maxY - minY + 1;
      const boxArea = boxW * boxH;
      const fill = area / boxArea;
      const aspect = boxW / boxH;
      if (area < total * 0.012) continue;
      if (boxW < width * 0.08 || boxH < height * 0.08) continue;
      if (boxW > width * 0.96 && boxH > height * 0.96) continue;
      if (aspect < 0.18 || aspect > 8) continue;
      if (fill < 0.16) continue;

      const centerX = (minX + maxX) / 2 / width;
      const centerY = (minY + maxY) / 2 / height;
      const centered = 1 - Math.min(0.55, Math.hypot(centerX - 0.5, centerY - 0.5));
      const score = area * Math.min(fill, 0.9) * centered;
      if (!best || score > best.score) best = { score, minX, minY, maxX, maxY };
    }

    if (!best) return null;
    const pad = Math.max(2, Math.round(Math.min(width, height) * 0.018));
    const minX = Math.max(0, best.minX - pad);
    const minY = Math.max(0, best.minY - pad);
    const maxX = Math.min(width - 1, best.maxX + pad);
    const maxY = Math.min(height - 1, best.maxY + pad);
    const out = {
      x: minX / width,
      y: minY / height,
      w: (maxX - minX + 1) / width,
      h: (maxY - minY + 1) / height,
    };
    if (out.w > 0.985 && out.h > 0.985) return null;
    return out;
  }

  function detectProjectedLabel(mask: Uint8Array, width: number, height: number): typeof crop | null {
    const row = new Float32Array(height);
    for (let y = 0; y < height; y++) {
      let count = 0;
      const off = y * width;
      for (let x = 0; x < width; x++) count += mask[off + x];
      row[y] = count / width;
    }

    const smoothRows = smooth(row, Math.max(2, Math.round(height * 0.012)));
    const rowCut = Math.max(0.055, percentile(smoothRows, 0.72) * 0.72);
    const yBand = widestDenseBand(smoothRows, rowCut, Math.round(height * 0.08));
    if (!yBand) return null;

    const transition = new Float32Array(width);
    for (let x = 1; x < width; x++) {
      let count = 0;
      for (let y = yBand.start; y <= yBand.end; y++) {
        count += Math.abs(mask[y * width + x] - mask[y * width + x - 1]);
      }
      transition[x] = count / (yBand.end - yBand.start + 1);
    }
    const smoothTransition = smooth(transition, Math.max(2, Math.round(width * 0.006)));
    const transitionCut = Math.max(0.045, percentile(smoothTransition, 0.88) * 0.52);
    let edgeLeft = -1;
    let edgeRight = -1;
    const edgeInset = Math.round(width * 0.018);
    for (let x = edgeInset; x < width - edgeInset; x++) {
      if (smoothTransition[x] >= transitionCut) {
        edgeLeft = x;
        break;
      }
    }
    for (let x = width - edgeInset - 1; x > edgeInset; x--) {
      if (smoothTransition[x] >= transitionCut) {
        edgeRight = x;
        break;
      }
    }

    const col = new Float32Array(width);
    for (let x = 0; x < width; x++) {
      let count = 0;
      for (let y = yBand.start; y <= yBand.end; y++) count += mask[y * width + x];
      col[x] = count / (yBand.end - yBand.start + 1);
    }

    const smoothCols = smooth(col, Math.max(2, Math.round(width * 0.01)));
    const colCut = Math.max(0.045, percentile(smoothCols, 0.66) * 0.55);
    const xBand = widestDenseBand(smoothCols, colCut, Math.round(width * 0.12));
    if (!xBand) return null;

    if (edgeLeft >= 0 && edgeRight > edgeLeft && edgeRight - edgeLeft > width * 0.18) {
      const projectedLeft = xBand.start;
      const projectedRight = xBand.end;
      const leftIsPlausible = edgeLeft <= projectedLeft + width * 0.12;
      const rightIsPlausible = edgeRight >= projectedRight - width * 0.12;
      if (leftIsPlausible) xBand.start = Math.max(0, Math.min(xBand.start, edgeLeft));
      if (rightIsPlausible) xBand.end = Math.min(width - 1, Math.max(xBand.end, edgeRight));
    }

    trimBandEdges(smoothCols, xBand, Math.max(colCut * 0.72, 0.028));

    const padX = Math.round(width * 0.018);
    const padY = Math.round(height * 0.018);
    const minX = Math.max(0, xBand.start - padX);
    const maxX = Math.min(width - 1, xBand.end + padX);
    const minY = Math.max(0, yBand.start - padY);
    const maxY = Math.min(height - 1, yBand.end + padY);
    const out = {
      x: minX / width,
      y: minY / height,
      w: (maxX - minX + 1) / width,
      h: (maxY - minY + 1) / height,
    };
    if (out.w < 0.12 || out.h < 0.08) return null;
    if (out.w > 0.985 && out.h > 0.985) return null;
    return out;
  }

  function trimBandEdges(values: Float32Array, band: { start: number; end: number }, cut: number) {
    const maxWeakRun = Math.max(3, Math.round(values.length * 0.018));
    let weak = 0;
    for (let x = band.start; x <= band.end; x++) {
      if (values[x] >= cut) {
        if (weak > 0 && weak <= maxWeakRun) break;
        if (weak > maxWeakRun) band.start = x;
        break;
      }
      weak++;
    }
    weak = 0;
    for (let x = band.end; x >= band.start; x--) {
      if (values[x] >= cut) {
        if (weak > 0 && weak <= maxWeakRun) break;
        if (weak > maxWeakRun) band.end = x;
        break;
      }
      weak++;
    }
  }

  function smooth(values: Float32Array, radius: number): Float32Array {
    const out = new Float32Array(values.length);
    for (let i = 0; i < values.length; i++) {
      let sum = 0;
      let n = 0;
      for (let j = Math.max(0, i - radius); j <= Math.min(values.length - 1, i + radius); j++) {
        sum += values[j];
        n++;
      }
      out[i] = sum / n;
    }
    return out;
  }

  function percentile(values: Float32Array, p: number): number {
    const arr = Array.from(values).sort((a, b) => a - b);
    return arr[Math.max(0, Math.min(arr.length - 1, Math.round((arr.length - 1) * p)))] ?? 0;
  }

  function widestDenseBand(values: Float32Array, cut: number, minWidth: number): { start: number; end: number } | null {
    let best: { start: number; end: number; score: number } | null = null;
    let start = -1;
    let gap = 0;
    const maxGap = Math.max(2, Math.round(values.length * 0.025));
    for (let i = 0; i <= values.length; i++) {
      const dense = i < values.length && values[i] >= cut;
      if (dense) {
        if (start < 0) start = i;
        gap = 0;
      } else if (start >= 0) {
        gap++;
        if (gap > maxGap || i === values.length) {
          const end = Math.max(start, i - gap);
          const width = end - start + 1;
          if (width >= minWidth) {
            let score = width;
            for (let j = start; j <= end; j++) score += values[j] * 8;
            if (!best || score > best.score) best = { start, end, score };
          }
          start = -1;
          gap = 0;
        }
      }
    }
    return best ? { start: best.start, end: best.end } : null;
  }

  function sourceForExport(item: Item): HTMLCanvasElement {
    if (!item.source) throw new Error('image not loaded');
    if (!isCrop) return transformCanvas(item.source);
    const sx = Math.round(crop.x * item.source.width);
    const sy = Math.round(crop.y * item.source.height);
    const sw = Math.max(1, Math.round(crop.w * item.source.width));
    const sh = Math.max(1, Math.round(crop.h * item.source.height));
    const out = document.createElement('canvas');
    out.width = sw;
    out.height = sh;
    const ctx = out.getContext('2d');
    if (!ctx) throw new Error('canvas unavailable');
    ctx.drawImage(item.source, sx, sy, sw, sh, 0, 0, sw, sh);
    return out;
  }

  async function canvasToBlob(canvas: HTMLCanvasElement, out: Output): Promise<Blob> {
    const mime = out === 'png' ? 'image/png' : out === 'webp' ? 'image/webp' : 'image/jpeg';
    let source = canvas;
    if (out === 'jpg') {
      source = document.createElement('canvas');
      source.width = canvas.width;
      source.height = canvas.height;
      const ctx = source.getContext('2d');
      if (!ctx) throw new Error('canvas unavailable');
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, source.width, source.height);
      ctx.drawImage(canvas, 0, 0);
    }
    const blob = await new Promise<Blob | null>((resolve) => source.toBlob(resolve, mime, quality()));
    if (!blob) throw new Error('could not encode');
    return blob;
  }

  function uniqueName(base: string, ext: string, seen: Set<string>): string {
    let name = `${base}.${ext}`;
    let n = 2;
    while (seen.has(name)) { name = `${base} (${n}).${ext}`; n++; }
    seen.add(name);
    return name;
  }

  exportBtn.addEventListener('click', async () => {
    if (items.length === 0 || working) return;
    working = true;
    exportBtn.disabled = true;
    const out = readOutput();
    const suffix = isCrop ? 'cropped' : 'rotated';
    setProgress(1, isCrop ? 'Cropping' : `Rotating 1 of ${items.length}`);
    try {
      const blobs: { name: string; blob: Blob }[] = [];
      const seen = new Set<string>();
      for (let i = 0; i < items.length; i++) {
        const item = items[i];
        setProgress((i / items.length) * 90 + 3, isCrop ? 'Cropping' : `Rotating ${i + 1} of ${items.length}`);
        await loadItem(item);
        const canvas = sourceForExport(item);
        const blob = await canvasToBlob(canvas, out);
        blobs.push({ name: uniqueName(`${stripExtension(item.file.name)}-${suffix}`, out, seen), blob });
      }
      setProgress(95, 'Packaging');
      if (blobs.length === 1) {
        downloadBlob(blobs[0].blob, blobs[0].name);
      } else {
        const zip = new JSZip();
        for (const item of blobs) zip.file(item.name, item.blob);
        const zipBlob = await zip.generateAsync({ type: 'blob' });
        downloadBlob(zipBlob, `dtmp-${mode}-${todayStamp()}.zip`);
      }
      setProgress(100, `Done · ${blobs.length} file${blobs.length === 1 ? '' : 's'}`);
    } catch (err) {
      console.error(err);
      showErr('Something went wrong while exporting the image.');
      setProgress(0, 'Idle');
    } finally {
      working = false;
      setTimeout(() => setProgress(0, 'Idle'), 1800);
      render();
    }
  });

  updateOutputUI();
</script>
