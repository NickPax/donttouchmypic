---
// Universal client-side image converter, shared by /convert, /heic-to-jpg
// and /heic-to-pdf. Drop any common raster image; the tool auto-detects the
// input format and re-encodes it to the format you pick (JPG / PNG / WebP /
// PDF). HEIC/HEIF decode through heic2any (libheif WASM, lazily imported);
// everything else decodes via the browser's own Canvas pipeline. PDF output
// is assembled with pdf-lib. Single files download directly, batches are
// bundled into a zip via JSZip. Nothing leaves the tab.
import AdSlot from '../AdSlot.astro';

type Props = { defaultOutput?: 'jpg' | 'png' | 'webp' | 'pdf' };
const { defaultOutput = 'jpg' } = Astro.props;
const formats = ['jpg', 'png', 'webp', 'pdf'] as const;
---
<section id="tool" class="mx-auto max-w-[1320px] px-5 sm:px-8 pt-10 pb-16">
  <div class="grid lg:grid-cols-[minmax(0,1fr)_320px] gap-8">
    <div>
      <!-- iOS heads-up: revealed by inline script when on iPhone/iPad -->
      <div id="ios-note" hidden class="mb-5 card p-4 flex items-start gap-3">
        <span class="shrink-0 mt-0.5 inline-flex w-6 h-6 items-center justify-center rounded-sm bg-[var(--color-emerald-lt)] text-[var(--color-emerald-dk)] font-mono text-[11px] font-bold">i</span>
        <div class="min-w-0 text-sm leading-relaxed">
          <div class="font-display text-[17px] leading-tight">On iPhone? HEIC photos may already arrive as JPG.</div>
          <p class="mt-1 text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">
            Safari converts HEIC to JPEG when you upload from the Photos app. That's fine if you just want a JPG — but to convert the true original, open the <strong class="font-semibold">Files</strong> app and share from there, or set <strong class="font-semibold">Settings → Photos → Transfer to Mac or PC → Keep Originals</strong>.
          </p>
        </div>
      </div>

      <!-- Drop zone -->
      <div
        id="dropzone"
        class="drop-target relative rounded-sm p-10 md:p-14 text-center cursor-pointer"
        role="button"
        tabindex="0"
        aria-label="Drop images here, or click to browse"
      >
        <div class="scanline rounded-sm" data-scanline hidden></div>
        <div class="relative">
          <div class="mx-auto w-14 h-14 inline-flex items-center justify-center rounded-sm bg-[var(--color-emerald-lt)] text-[var(--color-emerald-dk)]">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="7" height="11" rx="1"/><rect x="14" y="8" width="7" height="11" rx="1"/><path d="M10 12h4"/><path d="M13 9l2 3-2 3"/></svg>
          </div>
          <h2 class="mt-5 display-3">Drop your images here.</h2>
          <p class="mt-2 text-sm text-[color-mix(in_srgb,var(--color-ink)_75%,transparent)]">
            Drag straight from a file window — or <button type="button" id="browse" class="underline decoration-[var(--color-emerald-dk)] decoration-2 underline-offset-4">browse</button>.
            HEIC, JPG, PNG, WebP, GIF &amp; more · as many as your browser can hold.
          </p>
        </div>
        <!-- No HTML-side accept filter. Different desktop browsers / OS
             versions handle HEIC in the file picker inconsistently (Chrome
             on macOS over-filters even extension-only accept; some Safari
             versions misinterpret the .heic extension UTI). Letting the
             picker show all files and validating via JS magic-byte sniff
             on selection is bulletproof across browsers. The iOS branch
             below sets accept at runtime to surface the Photos library. -->
        <input id="file-input" type="file" multiple class="sr-only" />
      </div>

      <!-- File panel -->
      <div id="file-panel" class="mt-6 hidden">
        <div class="card p-5">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <div class="flex items-center gap-2.5">
              <span class="chip chip-ink" id="chip-count">0 files</span>
              <span class="chip" id="chip-size">0 B</span>
            </div>
            <div class="flex items-center gap-2">
              <button type="button" id="add-more" class="btn btn-ghost !py-2 !px-3">Add more</button>
              <button type="button" id="clear-all" class="btn btn-ghost !py-2 !px-3">Clear</button>
            </div>
          </div>

          <ul id="file-list" class="divide-y divide-[var(--color-rule)]"></ul>

          <!-- Output format -->
          <div class="mt-6 rule pt-5">
            <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
              Convert to
            </div>
            <div class="mt-2 grid grid-cols-4 gap-2" role="radiogroup" aria-label="Output format">
              {formats.map((fmt) => (
                <label class="cursor-pointer">
                  <input type="radio" name="output" value={fmt} checked={fmt === defaultOutput} class="sr-only peer" />
                  <span class="block text-center py-2 px-2 rounded-sm border border-[var(--color-rule)] font-mono text-xs uppercase tracking-[0.1em] peer-checked:bg-[var(--color-navy-800)] peer-checked:text-[var(--color-paper)] peer-checked:border-[var(--color-navy-800)] transition-colors">{fmt}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Quality -->
          <div id="quality-block" class="mt-6 rule pt-5">
            <div class="flex items-center justify-between">
              <label for="quality" class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
                Image quality
              </label>
              <span class="font-mono text-sm"><span id="quality-val">92</span>%</span>
            </div>
            <input id="quality" type="range" min="50" max="100" step="1" value="92" class="w-full mt-3 accent-[var(--color-emerald-dk)]" />
            <p class="mt-2 text-xs text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
              Applies to JPG, WebP and PDF output. Higher = bigger file, closer to the original. 92% is a good sweet spot. PNG is lossless, so quality doesn't apply.
            </p>
          </div>

          <!-- PDF options -->
          <div id="pdf-options" class="mt-6 rule pt-5 space-y-5 hidden">
            <label class="flex items-start gap-3 cursor-pointer">
              <input id="combine-toggle" type="checkbox" checked class="mt-0.5 w-4 h-4 accent-[var(--color-emerald-dk)]" />
              <span>
                <span class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Combine into one PDF</span>
                <span class="block mt-1 text-xs text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">On — every image becomes a page in a single PDF. Off — each image gets its own PDF (zipped if there's more than one).</span>
              </span>
            </label>

            <div>
              <div class="font-mono text-[11px] tracking-[0.14em] uppercase text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">Page size</div>
              <div class="mt-2 flex gap-2" role="radiogroup" aria-label="Page size">
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="pagesize" value="photo" checked class="sr-only peer" />
                  <span class="block text-center py-2 px-3 rounded-sm border border-[var(--color-rule)] font-mono text-xs uppercase tracking-[0.1em] peer-checked:bg-[var(--color-navy-800)] peer-checked:text-[var(--color-paper)] peer-checked:border-[var(--color-navy-800)] transition-colors">Photo-sized</span>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="pagesize" value="a4" class="sr-only peer" />
                  <span class="block text-center py-2 px-3 rounded-sm border border-[var(--color-rule)] font-mono text-xs uppercase tracking-[0.1em] peer-checked:bg-[var(--color-navy-800)] peer-checked:text-[var(--color-paper)] peer-checked:border-[var(--color-navy-800)] transition-colors">A4</span>
                </label>
              </div>
              <p class="mt-2 text-xs text-[color-mix(in_srgb,var(--color-ink)_70%,transparent)]">
                Photo-sized — each page is exactly the image, no whitespace. A4 — images centered on standard pages, ready to print.
              </p>
            </div>
          </div>

          <!-- Action bar -->
          <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rule pt-5">
            <div class="w-full min-w-0 sm:flex-1">
              <div class="flex items-center justify-between mb-1.5 font-mono text-[11px] tracking-[0.12em] uppercase text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">
                <span id="status-label">Idle</span>
                <span id="progress-num">0%</span>
              </div>
              <div class="bar"><span id="progress-bar" style="width:0%"></span></div>
              <div class="mt-3 grid grid-cols-[1fr_auto_1fr] gap-2 sm:gap-4 items-center">
                <div class="min-w-0">
                  <div class="kicker text-[10px]">Source</div>
                  <div class="font-display text-[22px] sm:text-[26px] leading-none mt-0.5 truncate" id="in-stat">—</div>
                </div>
                <span class="font-mono text-[16px] text-[color-mix(in_srgb,var(--color-ink)_55%,transparent)]" aria-hidden="true">→</span>
                <div class="min-w-0">
                  <div class="kicker text-[10px]">Output</div>
                  <div class="font-display text-[22px] sm:text-[26px] leading-none mt-0.5 truncate" id="out-stat">—</div>
                </div>
              </div>
              <div class="mt-1 text-[11px] font-mono text-[var(--color-emerald-dk)] hidden" id="saved-line"></div>
            </div>
            <button id="convert-btn" class="btn btn-primary" disabled>
              Convert &amp; download
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 3v14M6 11l6 6 6-6M5 21h14"/></svg>
            </button>
          </div>
        </div>
      </div>

      <div id="err" role="alert" class="mt-6 hidden border border-[var(--color-red-stamp)] bg-[color-mix(in_srgb,#f4d6d1_50%,transparent)] text-[var(--color-red-stamp)] font-mono text-xs uppercase tracking-[0.14em] p-3 rounded-sm"></div>
    </div>

    <aside class="space-y-5">
      <div class="card p-5">
        <div class="section-num">Local runtime</div>
        <h3 class="font-display text-[22px] mt-1 leading-tight">What's running?</h3>
        <ul class="mt-3 text-sm space-y-2 font-mono">
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Decoder</span><span>Canvas 2D / libheif</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Encoder</span><span id="encoder-line">Canvas → JPEG</span></li>
          <li class="flex justify-between gap-4"><span class="text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">Network</span><span class="text-[var(--color-emerald-dk)]">idle</span></li>
        </ul>
      </div>
      <AdSlot position="convert-sidebar" size="300x250" />
      <div class="card-ink p-5">
        <div class="font-mono text-[11px] tracking-[0.2em] uppercase opacity-80">Good to know</div>
        <p class="mt-2 text-[15px] leading-relaxed">
          Re-encoding the image <em class="font-display not-italic">strips EXIF metadata</em> — location, camera and timestamp — so your converted file comes out clean. Converting to JPG or PDF flattens any transparency onto a white background.
        </p>
      </div>
    </aside>
  </div>
</section>

<script>
  import JSZip from 'jszip';
  import { formatBytes, downloadBlob, stripExtension, todayStamp } from '../../lib/format.ts';

  type Status = 'ready' | 'converting' | 'done' | 'error';
  type Output = 'jpg' | 'png' | 'webp' | 'pdf';
  type Item = {
    id: string;
    file: File;
    status: Status;
    // Detected input format, e.g. 'heic', 'jpg', 'png' — shown on the badge
    // and used to pick the decode path.
    format: string;
    // Canvas-encoded raster: the deliverable for jpg/png/webp output, and
    // the embed source + thumbnail for pdf output (always a JPEG there).
    rasterBlob?: Blob;
    rasterSize?: number;
    // Per-file PDF, only set when output is pdf and "combine" is off.
    pdfBlob?: Blob;
    pdfSize?: number;
    error?: string;
    // Lazy-allocated object URL pointing at rasterBlob, used as the
    // thumbnail src. Revoked when the item is removed or the list cleared.
    previewUrl?: string;
  };

  const dropzone    = document.getElementById('dropzone') as HTMLDivElement;
  const input       = document.getElementById('file-input') as HTMLInputElement;
  const browse      = document.getElementById('browse') as HTMLButtonElement;
  const panel       = document.getElementById('file-panel') as HTMLDivElement;
  const listEl      = document.getElementById('file-list') as HTMLUListElement;
  const chipCount   = document.getElementById('chip-count') as HTMLSpanElement;
  const chipSize    = document.getElementById('chip-size') as HTMLSpanElement;
  const addMoreBtn  = document.getElementById('add-more') as HTMLButtonElement;
  const clearBtn    = document.getElementById('clear-all') as HTMLButtonElement;
  const qBlock      = document.getElementById('quality-block') as HTMLDivElement;
  const qSlider     = document.getElementById('quality') as HTMLInputElement;
  const qVal        = document.getElementById('quality-val') as HTMLSpanElement;
  const pdfOptions  = document.getElementById('pdf-options') as HTMLDivElement;
  const combineEl   = document.getElementById('combine-toggle') as HTMLInputElement;
  const encoderLine = document.getElementById('encoder-line') as HTMLSpanElement;
  const convertBtn  = document.getElementById('convert-btn') as HTMLButtonElement;
  const progBar     = document.getElementById('progress-bar') as HTMLSpanElement;
  const progNum     = document.getElementById('progress-num') as HTMLSpanElement;
  const statusLabel = document.getElementById('status-label') as HTMLSpanElement;
  const inStat      = document.getElementById('in-stat') as HTMLDivElement;
  const outStat     = document.getElementById('out-stat') as HTMLDivElement;
  const savedLine   = document.getElementById('saved-line') as HTMLDivElement;
  const errEl       = document.getElementById('err') as HTMLDivElement;
  const scan        = dropzone.querySelector('[data-scanline]') as HTMLDivElement;

  const items: Item[] = [];
  let working = false;

  // Snapshot of how the last batch was assembled, used by render() to show
  // the Output stat. A combined PDF has no per-file size, so its total is
  // captured here once the document is built.
  let combineForStats = false;
  let combinedOutSize = 0;

  function readOutput(): Output {
    const checked = document.querySelector('input[name="output"]:checked') as HTMLInputElement | null;
    const v = checked?.value;
    return v === 'png' || v === 'webp' || v === 'pdf' ? v : 'jpg';
  }
  function readPageSize(): 'photo' | 'a4' {
    const checked = document.querySelector('input[name="pagesize"]:checked') as HTMLInputElement | null;
    return checked?.value === 'a4' ? 'a4' : 'photo';
  }

  let errTimer: ReturnType<typeof setTimeout> | undefined;
  function showErr(msg: string, persist = false) {
    if (errTimer) { clearTimeout(errTimer); errTimer = undefined; }
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
    if (!persist) errTimer = setTimeout(() => errEl.classList.add('hidden'), 6000);
  }
  function setProgress(pct: number, label?: string) {
    const c = Math.max(0, Math.min(100, pct));
    progBar.style.width = `${c}%`;
    progNum.textContent = `${Math.round(c)}%`;
    if (label) statusLabel.textContent = label;
  }

  // ISO BMFF (HEIC/HEIF/AVIF) major brands.
  const HEIC_BRANDS = new Set([
    'heic','heix','heim','heis',
    'mif1','msf1',
    'hevc','hevx','hevm','hevs',
  ]);

  // Magic-byte detector. Returns a short format key, or null if the file
  // isn't a raster image we can decode.
  async function detectImageFormat(f: File): Promise<string | null> {
    try {
      const buf = await f.slice(0, 32).arrayBuffer();
      const b = new Uint8Array(buf);
      if (b.length < 12) return null;
      if (b[0] === 0xff && b[1] === 0xd8 && b[2] === 0xff) return 'jpg';
      if (b[0] === 0x89 && b[1] === 0x50 && b[2] === 0x4e && b[3] === 0x47) return 'png';
      if (b[0] === 0x47 && b[1] === 0x49 && b[2] === 0x46) return 'gif';
      if (b[0] === 0x42 && b[1] === 0x4d) return 'bmp';
      const riff = String.fromCharCode(b[0], b[1], b[2], b[3]);
      const webp = String.fromCharCode(b[8], b[9], b[10], b[11]);
      if (riff === 'RIFF' && webp === 'WEBP') return 'webp';
      const ftyp = String.fromCharCode(b[4], b[5], b[6], b[7]);
      if (ftyp === 'ftyp') {
        const brand = String.fromCharCode(b[8], b[9], b[10], b[11]);
        if (HEIC_BRANDS.has(brand)) return 'heic';
        if (brand === 'avif' || brand === 'avis') return 'avif';
      }
      // Fallback for files with no/short magic but a clear extension.
      const name = f.name.toLowerCase();
      if (name.endsWith('.heic') || name.endsWith('.heif')) return 'heic';
      return null;
    } catch {
      return null;
    }
  }

  const UA = navigator.userAgent;
  const IS_IOS = /iPad|iPhone|iPod/.test(UA)
    || (navigator.platform === 'MacIntel' && (navigator as any).maxTouchPoints > 1);

  if (IS_IOS) {
    const note = document.getElementById('ios-note');
    if (note) note.removeAttribute('hidden');
    // iOS only: set accept to surface the Photos library. Desktop
    // intentionally has no accept filter — see the input's HTML comment.
    input.setAttribute('accept', 'image/*,.heic,.heif');
  }

  // --- Output-format UI ---
  function updateOutputUI() {
    const out = readOutput();
    qBlock.classList.toggle('hidden', out === 'png');
    pdfOptions.classList.toggle('hidden', out !== 'pdf');
    encoderLine.textContent =
      out === 'pdf'  ? 'Canvas → JPEG → PDF' :
      out === 'png'  ? 'Canvas → PNG' :
      out === 'webp' ? 'Canvas → WebP' :
                       'Canvas → JPEG';
    render();
  }
  document.querySelectorAll('input[name="output"]').forEach((el) =>
    el.addEventListener('change', updateOutputUI));

  function render() {
    if (items.length === 0) {
      panel.classList.add('hidden');
      return;
    }
    panel.classList.remove('hidden');

    const out = readOutput();
    const totalSize = items.reduce((acc, it) => acc + it.file.size, 0);
    // Output total: jpg/png/webp sum the raster sizes; pdf sums the per-file
    // PDF sizes, except in combine mode where the single document is the total.
    const totalOut = out !== 'pdf'
      ? items.reduce((acc, it) => acc + (it.rasterSize ?? 0), 0)
      : combineForStats
        ? combinedOutSize
        : items.reduce((acc, it) => acc + (it.pdfSize ?? 0), 0);
    chipCount.textContent = `${items.length} file${items.length === 1 ? '' : 's'}`;
    chipSize.textContent  = formatBytes(totalSize);

    inStat.textContent  = formatBytes(totalSize);
    const doneCount = items.filter((i) => i.status === 'done').length;
    if (doneCount > 0 && totalOut > 0) {
      outStat.textContent = formatBytes(totalOut);
      const doneInputBytes = items
        .filter((i) => i.status === 'done')
        .reduce((acc, it) => acc + it.file.size, 0);
      if (doneInputBytes > totalOut) {
        const pct = Math.round((1 - totalOut / doneInputBytes) * 100);
        savedLine.textContent = `Saved ${pct}% across ${doneCount} file${doneCount === 1 ? '' : 's'}`;
        savedLine.classList.remove('hidden');
      } else {
        savedLine.classList.add('hidden');
      }
    } else {
      outStat.textContent = '—';
      savedLine.classList.add('hidden');
    }

    listEl.innerHTML = '';
    for (const item of items) {
      listEl.appendChild(renderItem(item, out));
    }

    const anyReady = items.some((i) => i.status === 'ready');
    convertBtn.disabled = working || !anyReady;
  }

  function renderItem(item: Item, out: Output): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'py-3 flex items-center gap-3 min-w-0';

    const badge = document.createElement('span');
    badge.className = 'shrink-0 w-10 h-12 border border-[var(--color-rule)] rounded-sm overflow-hidden flex items-center justify-center font-mono text-[10px] tracking-[0.1em] bg-[var(--color-paper)]';
    if (item.status === 'done' && item.rasterBlob) {
      if (!item.previewUrl) item.previewUrl = URL.createObjectURL(item.rasterBlob);
      const img = document.createElement('img');
      img.src = item.previewUrl;
      img.alt = '';
      img.loading = 'lazy';
      img.decoding = 'async';
      img.className = 'w-full h-full object-cover';
      badge.appendChild(img);
    } else {
      badge.textContent = item.format.toUpperCase();
    }
    li.appendChild(badge);

    const body = document.createElement('div');
    body.className = 'min-w-0 flex-1';
    const name = document.createElement('div');
    name.className = 'font-display text-[18px] truncate';
    name.textContent = item.file.name;
    const meta = document.createElement('div');
    meta.className = 'font-mono text-[11px] uppercase tracking-[0.12em] text-[color-mix(in_srgb,var(--color-ink)_60%,transparent)]';
    let metaText = formatBytes(item.file.size);
    if (item.status === 'converting') metaText += ' · converting…';
    else if (item.status === 'done') {
      if (out !== 'pdf') metaText += ` → ${formatBytes(item.rasterSize ?? 0)} · ${out.toUpperCase()}`;
      else if (item.pdfSize != null) metaText += ` → ${formatBytes(item.pdfSize)} · PDF`;
      else metaText += ' · added to PDF';
    }
    else if (item.status === 'error')  metaText += ` · ${item.error ?? 'error'}`;
    else                                metaText += ' · ready';
    meta.textContent = metaText;
    if (item.status === 'error')  meta.classList.add('text-[var(--color-red-stamp)]');
    if (item.status === 'done')   meta.classList.add('text-[var(--color-emerald-dk)]');
    body.appendChild(name);
    body.appendChild(meta);
    li.appendChild(body);

    const actions = document.createElement('div');
    actions.className = 'shrink-0 flex items-center gap-2';

    const remove = document.createElement('button');
    remove.type = 'button';
    remove.className = 'w-8 h-8 inline-flex items-center justify-center border border-[var(--color-rule)] rounded-sm hover:bg-[var(--color-paper-2)]';
    remove.setAttribute('aria-label', `Remove ${item.file.name}`);
    remove.innerHTML = '<svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 6l12 12M18 6L6 18"/></svg>';
    remove.disabled = item.status === 'converting';
    remove.addEventListener('click', () => {
      const idx = items.findIndex((i) => i.id === item.id);
      if (idx >= 0) {
        if (items[idx].previewUrl) URL.revokeObjectURL(items[idx].previewUrl!);
        items.splice(idx, 1);
      }
      render();
    });
    actions.appendChild(remove);

    li.appendChild(actions);
    return li;
  }

  async function addFiles(files: FileList | File[]) {
    const arr = Array.from(files);
    let accepted = 0;
    let rejected = 0;
    for (const f of arr) {
      const fmt = await detectImageFormat(f);
      if (fmt) {
        items.push({ id: crypto.randomUUID(), file: f, status: 'ready', format: fmt });
        accepted++;
      } else {
        rejected++;
      }
    }
    if (accepted === 0 && rejected > 0) {
      showErr('No supported images there — drop HEIC, JPG, PNG, WebP, GIF or BMP files.');
    } else if (rejected > 0) {
      showErr(`${rejected} file${rejected === 1 ? '' : 's'} skipped — not a supported image.`);
    }
    render();

    // After a successful add, make sure the Convert button is in view. On
    // phones the file panel + convert button live below the fold, and users
    // were dropping a file then wondering what to do next.
    if (accepted > 0) {
      requestAnimationFrame(() => {
        const rect = convertBtn.getBoundingClientRect();
        const fullyInView = rect.top >= 0 && rect.bottom <= window.innerHeight;
        if (!fullyInView) {
          convertBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }
  }

  // --- Drop zone wiring ---
  dropzone.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'browse') return;
    input.click();
  });
  dropzone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); }
  });
  browse.addEventListener('click', (e) => { e.stopPropagation(); input.click(); });

  function resetBatch() {
    for (const item of items) {
      if (item.previewUrl) URL.revokeObjectURL(item.previewUrl);
    }
    items.length = 0;
    combineForStats = false;
    combinedOutSize = 0;
    setProgress(0, 'Idle');
    render();
  }

  addMoreBtn.addEventListener('click', () => {
    // If the previous batch has already finished, treat "Add more" as
    // starting fresh: clear the list and reset the action bar, then open the
    // picker. Otherwise Source/Output sums would straddle the old batch.
    const finished = !working && items.some((i) => i.status === 'done' || i.status === 'error');
    if (finished) resetBatch();
    input.click();
  });
  clearBtn.addEventListener('click', () => {
    if (working) return;
    resetBatch();
  });

  ['dragenter', 'dragover'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    dropzone.classList.add('is-dragging');
    if (scan) scan.hidden = false;
  }));
  ['dragleave', 'drop'].forEach((evt) => dropzone.addEventListener(evt, (e) => {
    e.preventDefault();
    if (evt === 'dragleave' && (e.target !== dropzone)) return;
    dropzone.classList.remove('is-dragging');
    if (scan) scan.hidden = true;
  }));
  dropzone.addEventListener('drop', (e) => {
    if (!e.dataTransfer?.files) return;
    addFiles(e.dataTransfer.files);
  });
  input.addEventListener('change', () => {
    if (input.files) addFiles(input.files);
    input.value = '';
  });

  // --- Quality slider ---
  qSlider.addEventListener('input', () => { qVal.textContent = qSlider.value; });

  // --- Decode / encode pipeline ---
  // Decode any input file to an ImageBitmap. HEIC/HEIF route through
  // heic2any (lazily imported so non-HEIC use never loads the WASM); a
  // lossless PNG is used as the transport blob to avoid double-lossy
  // re-encoding. Everything else decodes via the browser directly.
  async function decodeToBitmap(item: Item): Promise<ImageBitmap> {
    if (item.format === 'heic' || item.format === 'heif') {
      const { default: heic2any } = await import('heic2any');
      const result = await heic2any({ blob: item.file, toType: 'image/png' });
      const blob: Blob = Array.isArray(result) ? result[0] : result;
      return await createImageBitmap(blob);
    }
    return await createImageBitmap(item.file, { imageOrientation: 'from-image' });
  }

  // Re-encode a bitmap to the chosen raster format. JPEG/PDF get a white
  // background fill so any transparency is flattened rather than turned black.
  async function encodeRaster(bitmap: ImageBitmap, out: Output, quality: number): Promise<Blob> {
    const canvas = document.createElement('canvas');
    canvas.width = bitmap.width;
    canvas.height = bitmap.height;
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('canvas unavailable');
    if (out === 'jpg' || out === 'pdf') {
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
    ctx.drawImage(bitmap, 0, 0);
    const mime = out === 'png' ? 'image/png' : out === 'webp' ? 'image/webp' : 'image/jpeg';
    const blob = await new Promise<Blob | null>((res) => canvas.toBlob(res, mime, quality));
    if (!blob) throw new Error('could not encode');
    return blob;
  }

  // A4 in PDF points (72 dpi): 595.28 × 841.89.
  const A4_SHORT = 595.28;
  const A4_LONG  = 841.89;
  const A4_MARGIN = 24;

  // Embed one JPEG as a page in the given PDFDocument.
  async function addJpegPage(pdf: any, jpegBlob: Blob, pageSize: 'photo' | 'a4') {
    const bytes = new Uint8Array(await jpegBlob.arrayBuffer());
    const img = await pdf.embedJpg(bytes);
    if (pageSize === 'a4') {
      // Orient the page to match the image so the fit is as large as possible.
      const landscape = img.width > img.height;
      const pw = landscape ? A4_LONG : A4_SHORT;
      const ph = landscape ? A4_SHORT : A4_LONG;
      const page = pdf.addPage([pw, ph]);
      const maxW = pw - A4_MARGIN * 2;
      const maxH = ph - A4_MARGIN * 2;
      const scale = Math.min(maxW / img.width, maxH / img.height, 1);
      const w = img.width * scale;
      const h = img.height * scale;
      page.drawImage(img, { x: (pw - w) / 2, y: (ph - h) / 2, width: w, height: h });
    } else {
      const page = pdf.addPage([img.width, img.height]);
      page.drawImage(img, { x: 0, y: 0, width: img.width, height: img.height });
    }
  }

  // Dedupe output names defensively: "IMG.jpg", "IMG (2).jpg", …
  function uniqueName(base: string, ext: string, seen: Set<string>): string {
    let name = `${base}.${ext}`;
    let n = 2;
    while (seen.has(name)) { name = `${base} (${n}).${ext}`; n++; }
    seen.add(name);
    return name;
  }

  // --- Conversion ---
  convertBtn.addEventListener('click', async () => {
    const toProcess = items.filter((i) => i.status === 'ready');
    if (toProcess.length === 0) return;

    working = true;
    convertBtn.disabled = true;
    const out = readOutput();
    const quality = Math.max(50, Math.min(100, +qSlider.value)) / 100;
    const combine = out === 'pdf' && !!combineEl.checked;
    const pageSize = out === 'pdf' ? readPageSize() : 'photo';
    combineForStats = combine;
    combinedOutSize = 0;

    setProgress(1, `Converting 1 of ${toProcess.length}`);

    // Phase 1 — decode + re-encode every file. With pdf output and combine
    // off, each file's single-page PDF is also built here so the Output stat
    // ticks up live; with combine on the document is assembled afterwards.
    for (let i = 0; i < toProcess.length; i++) {
      const item = toProcess[i];
      item.status = 'converting';
      render();
      setProgress(((i) / toProcess.length) * 88 + 2, `Converting ${i + 1} of ${toProcess.length}`);

      try {
        const bitmap = await decodeToBitmap(item);
        const raster = await encodeRaster(bitmap, out, quality);
        bitmap.close();
        item.rasterBlob = raster;
        item.rasterSize = raster.size;

        if (out === 'pdf' && !combine) {
          const { PDFDocument } = await import('pdf-lib');
          const pdf = await PDFDocument.create();
          await addJpegPage(pdf, raster, pageSize);
          const pdfBytes = await pdf.save();
          item.pdfBlob = new Blob([pdfBytes], { type: 'application/pdf' });
          item.pdfSize = item.pdfBlob.size;
        }

        item.status = 'done';
      } catch (err) {
        console.error(err);
        item.status = 'error';
        item.error  = (err as Error).message || 'could not convert';
      }
      render();
    }

    const done = items.filter((i) => i.status === 'done' && i.rasterBlob);
    if (done.length === 0) {
      showErr('No files could be converted. They may be corrupt or in an unsupported format.');
      setProgress(0, 'Idle');
      working = false;
      render();
      return;
    }

    setProgress(94, 'Packaging');

    try {
      if (out === 'pdf' && combine) {
        // Phase 2 — one document, one page per image.
        const { PDFDocument } = await import('pdf-lib');
        const pdf = await PDFDocument.create();
        for (const item of done) {
          await addJpegPage(pdf, item.rasterBlob!, pageSize);
        }
        const pdfBytes = await pdf.save();
        const blob = new Blob([pdfBytes], { type: 'application/pdf' });
        combinedOutSize = blob.size;
        const name = done.length === 1
          ? `${stripExtension(done[0].file.name)}.pdf`
          : `dtmp-convert-${todayStamp()}.pdf`;
        downloadBlob(blob, name);
        setProgress(100, `Done · 1 PDF · ${done.length} page${done.length === 1 ? '' : 's'}`);
      } else if (out === 'pdf') {
        // One PDF per image, built in phase 1; download or zip them.
        if (done.length === 1) {
          downloadBlob(done[0].pdfBlob!, `${stripExtension(done[0].file.name)}.pdf`);
          setProgress(100, 'Done · 1 PDF');
        } else {
          const zip = new JSZip();
          const names = new Set<string>();
          for (const item of done) {
            zip.file(uniqueName(stripExtension(item.file.name), 'pdf', names), item.pdfBlob!);
          }
          const zipBlob = await zip.generateAsync({ type: 'blob' });
          downloadBlob(zipBlob, `dtmp-convert-${todayStamp()}.zip`);
          setProgress(100, `Done · ${done.length} PDFs`);
        }
      } else {
        // Raster output: the re-encoded image is the deliverable.
        const ext = out;
        if (done.length === 1) {
          downloadBlob(done[0].rasterBlob!, `${stripExtension(done[0].file.name)}.${ext}`);
          setProgress(100, 'Done · 1 file');
        } else {
          const zip = new JSZip();
          const names = new Set<string>();
          for (const item of done) {
            zip.file(uniqueName(stripExtension(item.file.name), ext, names), item.rasterBlob!);
          }
          const zipBlob = await zip.generateAsync({ type: 'blob' });
          downloadBlob(zipBlob, `dtmp-convert-${todayStamp()}.zip`);
          setProgress(100, `Done · ${done.length} files`);
        }
      }
    } catch (err) {
      console.error(err);
      showErr('Something went wrong while packaging the download.');
      setProgress(0, 'Idle');
    }

    working = false;
    setTimeout(() => setProgress(0, 'Idle'), 1800);
    render();
  });

  // Initialise output-dependent UI on load.
  updateOutputUI();
</script>
