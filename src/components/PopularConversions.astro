---
// Compact "popular shortcuts" strip under the tool grid. The Convert tool
// handles every format pairing, but a couple of jobs are common enough to
// deserve a direct, pre-set link (and their own SEO landing pages).
const shortcuts = [
  { href: '/heic-to-jpg', label: 'HEIC → JPG', sub: 'iPhone photos, everywhere' },
  { href: '/heic-to-pdf', label: 'HEIC → PDF', sub: 'iPhone photos as a document' },
  { href: '/convert',     label: 'Convert',     sub: 'Any image, any format' },
];
---
<section class="mx-auto max-w-[1320px] px-5 sm:px-8 -mt-6">
  <div class="rule pt-6 flex flex-wrap items-center gap-x-8 gap-y-3">
    <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-[color-mix(in_srgb,var(--color-ink)_65%,transparent)]">
      Popular:
    </span>
    {shortcuts.map((s) => (
      <a
        href={s.href}
        class="group inline-flex items-baseline gap-2 underline-offset-[5px] decoration-[2px] decoration-transparent hover:decoration-[var(--color-emerald-dk)] underline transition-colors"
      >
        <span class="font-display text-[20px] leading-none">{s.label}<span class="text-[var(--color-emerald-dk)]">.</span></span>
        <span class="hidden sm:inline font-mono text-[11px] uppercase tracking-[0.1em] text-[color-mix(in_srgb,var(--color-ink)_55%,transparent)]">{s.sub}</span>
      </a>
    ))}
  </div>
</section>
