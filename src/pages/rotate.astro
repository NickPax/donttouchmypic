---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolHeader from '../components/ToolHeader.astro';
import ImageEditTool from '../components/tools/ImageEditTool.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import RelatedTools from '../components/RelatedTools.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE_NAME, SITE_URL } from '../lib/constants';

const title = 'Rotate images online — private, free, nothing uploads · ' + SITE_NAME;
const description = 'Rotate, straighten and flip JPG, PNG, WebP, GIF and iPhone HEIC images in your browser. Batch-friendly, private, free, no upload and no watermark.';

const steps = [
  { title: 'Drop one image or a batch', body: 'Add JPG, PNG, WebP, GIF, BMP or HEIC files. They stay in browser memory; nothing uploads.' },
  { title: 'Turn, flip or straighten', body: 'Use 90-degree buttons for sideways photos, flip horizontally or vertically, or fine-tune a tilted horizon with the straighten slider.' },
  { title: 'Download the fixed files', body: 'Single file? Direct download. Batch? The browser packs the rotated results into a zip.' },
];

const faq = [
  { q: 'Does rotate work on iPhone HEIC photos?', a: 'Yes. HEIC and HEIF decode locally with libheif through heic2any, then the rotation is rendered with Canvas.' },
  { q: 'Can I rotate a whole batch?', a: 'Yes. The same rotate, flip and straighten settings apply to every image in the batch, and multiple outputs download as a zip.' },
  { q: 'Can I fix a slightly crooked image?', a: 'Yes. Use the straighten slider for fine-angle rotation from -45° to 45°, in addition to the 90° left and right buttons.' },
  { q: 'Which format should I export?', a: '<strong>JPG</strong> is best for photos. <strong>PNG</strong> is lossless and keeps transparency. <strong>WebP</strong> is compact and works well for modern web use.' },
  { q: 'Is anything sent to a server?', a: 'No. The tool is a static browser bundle. Decoding, rotation, export and zip packaging all happen locally in the tab.' },
];

const sd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: `${SITE_NAME} Rotate Image`,
    url: `${SITE_URL}/rotate`,
    applicationCategory: 'Utilities',
    operatingSystem: 'Any (browser-based)',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
    })),
  },
];
---
<BaseLayout title={title} description={description} path="/rotate" structuredData={sd}>
  <ToolHeader
    kicker="Tool · 05"
    title="Rotate"
    tagline="Fix the angle without sending the file away."
    description="Turn sideways photos, straighten a horizon, flip a mirror image, and download the repaired result. Batch jobs stay local too."
    accent="navy"
  >
    <svg slot="icon" viewBox="0 0 24 24" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
  </ToolHeader>

  <ImageEditTool mode="rotate" />

  <AdSlot position="rotate-under-tool" size="970x250" />
  <HowItWorks steps={steps} heading="How rotation works" />
  <Faq items={faq} heading="Rotate images · FAQ" />
  <AdSlot position="rotate-faq-bottom" size="728x90" />
  <RelatedTools current="rotate" />
</BaseLayout>
